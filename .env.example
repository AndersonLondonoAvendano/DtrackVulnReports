# ── Dependency-Track ──────────────────────────────────────────────────────────
# URL base del backend de DT (puerto 8081 por defecto, NO el frontend 8080)
DT_BASE_URL=http://localhost:8081

# API Key de un team con permisos VIEW_PORTFOLIO y VIEW_VULNERABILITY
DT_API_KEY=your-api-key-here

# ── Base de datos ─────────────────────────────────────────────────────────────
# SQLite local (ruta relativa al directorio de trabajo del contenedor)
# Para PostgreSQL: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./data/vulntrack.db

# ── Sincronización ────────────────────────────────────────────────────────────
# Intervalo en horas para la sincronización automática con DT
SYNC_INTERVAL_HOURS=6

# ── Catálogo KEV (CISA) ───────────────────────────────────────────────────────
# Días de antigüedad del catálogo antes de mostrar aviso de desactualización
KEV_STALE_DAYS=7

# ── Seguridad web ─────────────────────────────────────────────────────────────
# Orígenes permitidos para CORS (separados por coma)
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ── Aplicación ────────────────────────────────────────────────────────────────
# Modo debug: activa logs legibles y recarga automática
DEBUG=false

# Nivel de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
